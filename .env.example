# Copy to `.env` (gitignored) and fill in values.
# Quickest path: `just setup` — writes .env with a freshly-generated token.

# Bearer token the Android app sends as `Authorization: Bearer <token>`.
# Must be at least 16 characters. Generate with:
#   openssl rand -hex 32
ZUN_TOKEN=

# Optional overrides — uncomment if the defaults don't suit you.
#
# ZUN_COMFY_URL=http://127.0.0.1:8188   # project-zun's `just serve` default
# ZUN_DATA_DIR=./data                    # where jobs.db, inputs/, outputs/ live
# RUST_LOG=zun_rust_server=info,tower_http=info,audit=info
