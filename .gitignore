/target
# Local config (contains token) — never committed.
config.toml
# Ignore everything under /data except:
#   - the workflows symlink pointing at ../../project-zun/workflows
#   - the committed prompts template (prompts.example.toml)
# The real `data/prompts.toml` stays local-only — never committed.
/data/*
!/data/workflows
!/data/prompts.example.toml
.claude
