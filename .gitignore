/target
# Local secret-bearing config (ZUN_TOKEN, etc.) — never committed.
.env
# Ignore everything under /data except:
#   - the workflows symlink pointing at ../../project-zun/workflows
#   - the committed prompts template (prompts.example.yaml)
# The real `data/prompts.yaml` stays local-only — never committed.
/data/*
!/data/workflows
!/data/prompts.example.yaml
.claude
