/target
# Local secret-bearing config (ZUN_TOKEN, etc.) — never committed.
.env
# Ignore everything under /data except the workflows symlink pointing
# at ../../project-zun/workflows. `data/prompts.yaml` is intentionally
# ignored — keep dev/production prompts out of git entirely. Set
# ZUN_PROMPTS_PATH in .env to point at a file outside the repo.
/data/*
!/data/workflows
.claude
